# ---------------------------------------------------------------------------
# Required for app (Vite client). Copy to .env or .env.local — never commit .env / .env.local.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: legacy names (used if above are not set)
# VITE_SUPABASE_2_URL=
# VITE_SUPABASE_2_ANON_KEY=

# ---------------------------------------------------------------------------
# Cloudinary (optional; use unsigned upload presets only — no API secret in frontend)
# ---------------------------------------------------------------------------
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_UPLOAD_PRESET_VIDEO=

# ---------------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=
VITE_APP_URL=
VITE_AFTER_SIGNIN_REDIRECT=/

# ---------------------------------------------------------------------------
# Optional feature flags / URLs
# ---------------------------------------------------------------------------
VITE_DATA_ENTRY_ALLOWED_EMAIL=
VITE_CONTACT_FORM_URL=
VITE_WEBINAR_PAYMENT_LINK=
VITE_WEBINAR_CONTACT_FORM_URL=

# ---------------------------------------------------------------------------
# Vercel serverless: Supabase proxy (/api/supabase-proxy). Set in Vercel dashboard.
# No VITE_ prefix — these run server-side only and are not exposed to the client.
# ---------------------------------------------------------------------------
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-public-key

# ---------------------------------------------------------------------------
# Server only (when running Express). Not used by Vercel static deploy.
# ---------------------------------------------------------------------------
# JWT_SECRET=
# PORT=
# DATABASE_URL=
